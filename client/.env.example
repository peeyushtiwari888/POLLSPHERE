# ==============================================================================
# 🌐 POLLSPHERE FRONTEND ENVIRONMENT CONFIGURATION (VITE)
# ==============================================================================
# This is an example file. Copy this file and rename it to `.env` in the 
# root of your `client/` folder. Do NOT commit the actual `.env` file to git.

# 1. API Configuration
# ------------------------------------------------------------------------------
# Set this to the URL where your Node.js/Express backend server is running.
# In local development, it's usually localhost:5000/api
# In production, it will be your real domain (e.g., https://api.pollsphere.com)
VITE_API_URL=http://localhost:5000/api

# 2. Other Frontend Settings
# ------------------------------------------------------------------------------
# You can add other public keys here (like Stripe or Google OAuth client IDs)
# VITE_GOOGLE_CLIENT_ID=your_public_client_id_here
